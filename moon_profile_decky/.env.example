# Copy to .env (gitignored - this repo is public) and fill in the real
# value. Baked into dist/index.js at build time (see rollup.config.js and
# src/env.ts) - this is a single personal SteamGridDB account for this
# plugin, not a per-install setting, so there's no runtime UI for it.
#
# Free key: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=
